@page "/_tfio/credentials"
@layout AppLayout
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using System.Security.Claims
@inject IPresignedUrlService Presign
@inject NavigationManager Nav

<PageTitle>Credentials — TinyFileIO</PageTitle>

<div class="page-header">
    <h1>Credentials</h1>
    <p>Your S3-compatible API credentials. Use your login username and password.</p>
</div>

<!-- ── S3 credentials ──────────────────────────────────────────── -->
<div class="panel mb-2">
    <div class="panel-title">
        <span>S3 API credentials</span>
    </div>
    <div class="panel-body">
        <p class="mb-1">Use these values when configuring any S3-compatible client.</p>
        <table class="tfio-table mb-1">
            <tbody>
                <tr>
                    <th>Endpoint</th>
                    <td><code>@_endpoint</code></td>
                </tr>
                <tr>
                    <th>Access Key ID</th>
                    <td><code>@_username</code></td>
                </tr>
                <tr>
                    <th>Secret Access Key</th>
                    <td><code>@(_showSecret ? _secret : "••••••••••••")</code>
                        <button class="tfio-btn tfio-btn-sm tfio-btn-secondary ms-1"
                                type="button" @onclick="() => _showSecret = !_showSecret">
                            @(_showSecret ? "Hide" : "Show")
                        </button>
                    </td>
                </tr>
                <tr>
                    <th>Region</th>
                    <td><code>us-east-1</code> <span class="tfio-muted">(any value accepted)</span></td>
                </tr>
                <tr>
                    <th>Signature version</th>
                    <td>SigV4 or SigV2</td>
                </tr>
                <tr>
                    <th>Path style</th>
                    <td>Enabled (virtual-hosted also supported)</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- ── Pre-signed URL generator ───────────────────────────────── -->
<div class="panel mb-2">
    <div class="panel-title">
        <span>Generate pre-signed URL</span>
        <button class="tfio-btn tfio-btn-sm tfio-btn-secondary" type="button"
                @onclick="() => _showPresign = !_showPresign">
            @(_showPresign ? "Collapse" : "Expand")
        </button>
    </div>
    @if (_showPresign)
    {
        <div class="panel-body">
            <div class="form-row mb-1">
                <div class="tfio-field">
                    <label>Bucket</label>
                    <input @bind="_psBucket" type="text" placeholder="my-bucket" />
                </div>
                <div class="tfio-field">
                    <label>Object key</label>
                    <input @bind="_psKey" type="text" placeholder="path/to/file.txt" />
                </div>
                <div class="tfio-field">
                    <label>Method</label>
                    <select @bind="_psMethod">
                        <option value="GET">GET (download)</option>
                        <option value="PUT">PUT (upload)</option>
                    </select>
                </div>
                <div class="tfio-field">
                    <label>Expires (seconds)</label>
                    <input @bind="_psExpires" type="number" min="60" max="604800" />
                </div>
                <div class="tfio-field tfio-field-inline" style="align-self:flex-end">
                    <button class="tfio-btn tfio-btn-primary" type="button"
                            @onclick="GeneratePresignAsync">Generate</button>
                </div>
            </div>
            @if (_psError is not null)
            {
                <div class="tfio-error mb-1">@_psError</div>
            }
            @if (_psUrl is not null)
            {
                <div class="tfio-field">
                    <label>Pre-signed URL (expires in @_psExpires s)</label>
                    <input readonly type="text" value="@_psUrl" @onclick="SelectAll" />
                </div>
            }
        </div>
    }
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private string _username = string.Empty;
    private string _secret   = string.Empty;
    private string _endpoint = string.Empty;
    private bool   _showSecret  = false;
    private bool   _showPresign = false;

    private string _psBucket  = string.Empty;
    private string _psKey     = string.Empty;
    private string _psMethod  = "GET";
    private int    _psExpires = 3600;
    private string? _psUrl;
    private string? _psError;

    private bool _isSuperAdmin;
    private string _userId = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _endpoint = new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority);

        if (AuthState is not null)
        {
            var state = await AuthState;
            var user  = state.User;
            _username    = user.Identity?.Name ?? string.Empty;
            _isSuperAdmin = user.IsInRole("SuperAdmin");
            _userId      = user.FindFirstValue(ClaimTypes.NameIdentifier) ?? string.Empty;

            // The secret is the plaintext password — we don't have it post-login,
            // so instruct the user to use their login password.
            _secret = "(your login password)";
        }
    }

    private async Task GeneratePresignAsync()
    {
        _psError = null;
        _psUrl   = null;

        if (string.IsNullOrWhiteSpace(_psBucket)) { _psError = "Bucket is required."; return; }
        if (string.IsNullOrWhiteSpace(_psKey))    { _psError = "Object key is required."; return; }
        if (_psExpires < 1)                        { _psError = "Expiry must be at least 1 second."; return; }

        try
        {
            var token = Presign.Create(
                _psMethod,
                _psBucket.Trim(),
                _psKey.Trim(),
                _userId,
                _username,
                _isSuperAdmin,
                _psExpires);

            _psUrl = $"{_endpoint}/{_psBucket.Trim()}/{_psKey.Trim()}?X-Tfio-Presign={Uri.EscapeDataString(token.Token)}";
        }
        catch (Exception ex)
        {
            _psError = ex.Message;
        }
    }

    private void SelectAll(MouseEventArgs e) { /* browser handles it */ }
}
